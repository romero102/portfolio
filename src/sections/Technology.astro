---
import { technologies } from '../content/technologies';
import { Icon } from 'astro-icon/components';
---

<section class="px-6 py-10">
  <p class="font-orbitron text-xs uppercase tracking-[0.15em] text-[#7c3aed] text-center mb-8">
    Stack técnico
  </p>

  <div class="flex flex-wrap justify-center gap-3 max-w-2xl mx-auto">
    {technologies.map((technology) => (
      <div class="flex flex-col items-center bg-[#0f0f1a] border border-[#1e1e3a] hover:border-[#7c3aed44] rounded-lg px-4 py-3 w-20 transition-colors group">
        <Icon
          class="w-8 h-8 text-[#7c3aed] group-hover:text-[#a78bfa] transition-colors"
          name={technology.icon}
        />
        <p class="font-onest text-xs text-slate-400 text-center mt-2 leading-tight">{technology.name}</p>
      </div>
    ))}
  </div>
</section>
