---
import { projects } from '../content/projects.js';
import { Icon } from 'astro-icon/components';
---

<section class="px-6 py-10">
  <p class="font-orbitron text-xs uppercase tracking-[0.15em] text-[#7c3aed] text-center mb-8">
    Proyectos
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-3xl mx-auto">
    {projects.map((project) => (
      <div class="bg-[#0f0f1a] border border-[#1e1e3a] hover:border-[#7c3aed44] rounded-xl overflow-hidden transition-colors group">

        {project.image && (
          <img
            src={project.image}
            alt={`Captura de ${project.name}`}
            class="w-full h-36 object-cover opacity-80 group-hover:opacity-100 transition-opacity"
          />
        )}

        <div class="p-5">
          <h3 class="font-orbitron text-sm text-white mb-2">{project.name}</h3>
          <p class="font-onest text-sm text-slate-400 leading-relaxed mb-4">{project.description}</p>

          <!-- Tags de tecnologías -->
          <div class="flex flex-wrap gap-2 mb-4">
            {project.technologies.map((tech) => (
              <span class="bg-[#1a1a2e] border border-[#7c3aed33] text-[#a78bfa] text-xs px-2 py-0.5 rounded font-onest">
                {tech}
              </span>
            ))}
          </div>

          <!-- Links -->
          <div class="flex gap-4">
            {project.page && (
              <a
                href={project.page}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-1 font-onest text-xs text-[#7c3aed] hover:text-[#a78bfa] transition-colors"
              >
                <Icon class="size-3.5" name="external-link" fill="none" />
                Demo
              </a>
            )}
            {project.github && (
              <a
                href={project.github}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-1 font-onest text-xs text-[#7c3aed] hover:text-[#a78bfa] transition-colors"
              >
                <Icon class="size-3.5" name="brand-github" fill="none" />
                GitHub
              </a>
            )}
          </div>
        </div>

      </div>
    ))}
  </div>
</section>
